{
  "name": "ankillm-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start": "npm run start --workspace=@ankillm/backend",
    "dev": "npm run dev --workspace=@ankillm/backend",
    "start:windows": "npm run start --workspace=@ankillm/windows",
    "build:windows": "npm run build --workspace=@ankillm/windows"
  },
  "devDependencies": {
    "7zip-bin": "^5.2.0"
  }
}
